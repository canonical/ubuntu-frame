{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigestsToSemver",
    "helpers:githubDigestChangelogs",
    "group:all",
    ":enablePreCommit"
  ],
  "packageRules": [
    {
      "matchPackageNames": ["myst-parser"],
      "matchFileNames": ["docs/requirements.txt"],
      "enabled": false
    }
  ]
}
